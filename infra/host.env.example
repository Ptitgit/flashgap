# Copy to host.env (gitignored) after provisioning the VPS.
# Used by infra/scripts/smoke-vps-provision.sh

# Public DNS name or hostname (documented in infra/README.md)
FLASHGAP_PUBLIC_HOSTNAME=api.example.flashgap.local

# SSH target (deploy user after provision-vps.sh)
FLASHGAP_SSH_HOST=203.0.113.50
FLASHGAP_SSH_USER=deploy
FLASHGAP_SSH_PORT=22

# Your fixed IP or VPN egress — must match UFW rule on port 22
FLASHGAP_SSH_RESTRICT_IP=203.0.113.10

# Hoster / region (documentation only)
FLASHGAP_HOSTER=hetzner
FLASHGAP_REGION=eu-central
