# Copier vers infra/.env (non versionné) : cp .env.example .env
# Usage local : docker compose --env-file .env up -d

# --- Postgres ---
POSTGRES_USER=flashgap
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=flashgap

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=flashgap_minio
MINIO_ROOT_PASSWORD=change_me_minio

# --- API (seul service exposé sur l'hôte) ---
API_PORT=3000
